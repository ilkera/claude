#!/bin/sh
#
# pre-push hook: Uses Claude to update CLAUDE.md for any project under this repo.
# Detects which project directories have code changes, and for each one that has
# a CLAUDE.md, asks Claude to review and update it if architecture changed.
# If any CLAUDE.md is updated, the push is aborted so you can review and re-push.
#
# Install: git config core.hooksPath scripts

remote="$1"
url="$2"

REPO_ROOT="$(git rev-parse --show-toplevel)"
CLAUDE_BIN="/opt/homebrew/bin/claude"

zero=$(git hash-object --stdin </dev/null | tr '[0-9a-f]' '0')

# Determine the range of commits being pushed
push_range=""
while read local_ref local_oid remote_ref remote_oid; do
    if test "$local_oid" = "$zero"; then
        continue
    fi
    if test "$remote_oid" = "$zero"; then
        push_range="$local_oid --not --remotes"
    else
        push_range="$remote_oid..$local_oid"
    fi
    break
done

if [ -z "$push_range" ]; then
    exit 0
fi

# Find project directories with code changes (exclude data/config files)
changed_projects=$(git diff --name-only $push_range 2>/dev/null \
    | grep -v '\.json$' \
    | grep -v '\.jsonl$' \
    | grep -v '__pycache__' \
    | grep -v '\.env' \
    | grep -v '\.DS_Store' \
    | cut -d'/' -f1 \
    | sort -u)

if [ -z "$changed_projects" ]; then
    exit 0
fi

claude_md_updated=false

for project in $changed_projects; do
    project_dir="$REPO_ROOT/$project"
    claude_md="$project_dir/CLAUDE.md"

    # Skip if not a directory or has no CLAUDE.md
    if [ ! -d "$project_dir" ] || [ ! -f "$claude_md" ]; then
        continue
    fi

    # Get the diff for this project
    diff_output=$(git diff $(echo $push_range | sed 's/ --not --remotes//' | head -1)..HEAD -- "$project/" 2>/dev/null)
    if [ -z "$diff_output" ]; then
        # Try alternate range format for new branches
        diff_output=$(git diff HEAD~5..HEAD -- "$project/" 2>/dev/null)
    fi
    if [ -z "$diff_output" ]; then
        continue
    fi

    echo "[pre-push] Checking if $project/CLAUDE.md needs updating..."

    $CLAUDE_BIN -p --allowedTools Edit Read Glob Grep \
        "You are reviewing code changes to decide if CLAUDE.md needs updating.

Here is the diff of changes being pushed for the '$project' project:

$diff_output

Review the diff above and the current CLAUDE.md at $claude_md.
Read CLAUDE.md first, then determine if the changes affect:
- Architecture or data flow
- New, renamed, or deleted files/modules
- New configuration options
- Changed component responsibilities
- New dependencies or tools
- Monitoring/dashboard changes

If YES: Update CLAUDE.md to reflect the changes. Keep the same style and structure. Be precise and minimal — only update what changed.
If NO: Do nothing.

IMPORTANT: Only update CLAUDE.md if there are genuine architectural or structural changes. Do NOT update for minor bug fixes, formatting, or cosmetic changes." 2>/dev/null

    # Check if CLAUDE.md was modified
    if ! git diff --quiet -- "$claude_md" 2>/dev/null; then
        claude_md_updated=true
        echo "[pre-push] Updated: $project/CLAUDE.md"
    fi
done

if [ "$claude_md_updated" = true ]; then
    echo ""
    echo "[pre-push] CLAUDE.md file(s) were updated to reflect architecture changes."
    echo "[pre-push] Review the changes, commit them, and push again:"
    echo ""
    echo "    git diff */CLAUDE.md"
    echo "    git add */CLAUDE.md && git commit -m 'Update CLAUDE.md for architecture changes'"
    echo "    git push"
    echo ""
    exit 1
fi

exit 0
